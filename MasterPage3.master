    <script type="text/javascript" language="javascript">

        $(document).ready(function () {
            /////////////////////////////////////////////
            $('input.enterastab, select.enterastab, textarea.enterastab').live('keydown', function (e) {
                if (e.keyCode == 13) {
                    var focusable = $('input,a,select,button,textarea').filter(':visible');
                    focusable.eq(focusable.index(this) + 1).focus();
                    return false;
                }
            });
            // adding same class 'enterastab' to all input element to act enter as tab
            $(':input[type=text],:checkbox,:radio,select').addClass('enterastab');

            //$(':input[id^="txt"]:not([id="txtRecoveryDue"])').addClass('enterastab');

            //$(':input[id^="txt"]:not([id="txtRecoveryDue"])').addClass('currency'); 

            //$(':checkbox,:radio,select').addClass('enterastab'); 


            $("#txtCusID").keydown(function (event) {
                if (event.keyCode == 13) {
                    $('#txtCusName').focus();
                }
            });



        })
    </script>
    <script type="text/javascript">
        $(function () {
            $("#ContentPlaceHolder1_ddlMedicine").change(function () {

                //alert('fffffff');


                var selectedText = $(this).find("option:selected").text();
                var selectedValue = $(this).val();
                //alert("Selected Text: " + selectedText + " Value: " + selectedValue);

                //var res = selectedText.split("//");
                var res = selectedText.split("~");

                //alert(res[0]);
                //alert(res[1]);

                document.getElementById("ContentPlaceHolder1_txtUnitPrice").value = res[3];
                //document.getElementById("intro").value = res[2];


                $("#ContentPlaceHolder1_txtQuantity").focus();

            });

            $("#ContentPlaceHolder1_ddlDiscountCode").change(function () {
                var selectedText = $(this).find("option:selected").text();
                var selectedValue = $(this).val();

                var totprice = document.getElementById("ContentPlaceHolder1_txtTotalPrice").value

                //alert(selectedValue);
                if (selectedValue == "0") {
                    document.getElementById("ContentPlaceHolder1_txtDiscount").value = 0.00;
                    document.getElementById("ContentPlaceHolder1_txtNetAmount").value = parseFloat(totprice);

                } else {

                    var discount = totprice * (parseInt(selectedValue) / 100);
                    //discount = discount.toFixed(0);

                    discount = Math.floor(discount);
                    document.getElementById("ContentPlaceHolder1_txtDiscount").value = parseFloat(discount);
                    document.getElementById("ContentPlaceHolder1_txtNetAmount").value = parseFloat(totprice) - parseFloat(discount);
                }

            });
        });
    </script>
