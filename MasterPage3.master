    <script type="text/javascript">
        $(function () {


            $("#ContentPlaceHolder1_txtUnitPrice").keyup(function () {
                $('#ContentPlaceHolder1_txtTotalBuyPrice').val($('#ContentPlaceHolder1_txtTotalPcs').val() * $('#ContentPlaceHolder1_txtUnitPrice').val());
                //$('#txtNetAmount').val($('#txtTotalBuyPrice').val() - $('#txtDiscount').val());
            });

            /*
            $("#txtTotalPcs").keyup(function () {
            $('#txtTotalBuyPrice').val($('#txtTotalPcs').val() * $('#txtUnitPrice').val());
            //$('#txtNetAmount').val($('#txtTotalBuyPrice').val() - $('#txtDiscount').val());
            });
            */
            $("#ContentPlaceHolder1_txtTotalBuyPrice").keyup(function () {

                if ($('#ContentPlaceHolder1_txtTotalPcs').val() != "") {
                    var v = $('#ContentPlaceHolder1_txtTotalBuyPrice').val() / $('#ContentPlaceHolder1_txtTotalPcs').val();
                    $('#ContentPlaceHolder1_txtUnitPrice').val(v.toFixed(2));
                    //$('#txtNetAmount').val($('#txtTotalBuyPrice').val() - $('#txtDiscount').val());
                }
            });


            $("#ContentPlaceHolder1_txtSellPrice").keyup(function () {
                var sellprice = $('#ContentPlaceHolder1_txtSellPrice').val() * $('#ContentPlaceHolder1_txtTotalPcs').val();
                //$('#txtTotalSellPrice').val($('#txtSellPrice').val() * $('#txtTotalPcs').val());
                $('#ContentPlaceHolder1_txtTotalSellPrice').val(sellprice.toFixed(2));
            });


            $("#ContentPlaceHolder1_txtTotalSellPrice").keyup(function () {
                var count = $('#ContentPlaceHolder1_txtTotalPcs').val();
                var unit_sell_price = parseFloat($('#ContentPlaceHolder1_txtTotalSellPrice').val()) / count;
                //$('#txtTotalSellPrice').val($('#txtSellPrice').val() * $('#txtTotalPcs').val());
                $('#ContentPlaceHolder1_txtSellPrice').val(unit_sell_price.toFixed(2));
            });



            $("#ContentPlaceHolder1_txtSpecialDiscount").keyup(function () {
                var factor = parseFloat($('#ContentPlaceHolder1_txtSpecialDiscount').val()) / parseFloat($('#ContentPlaceHolder1_txtTotalTP').val());
                //$('#txtTotalSellPrice').val($('#txtSellPrice').val() * $('#txtTotalPcs').val());
                $('#ContentPlaceHolder1_txtBuyPriceFactor').val(factor.toFixed(3));
            });



            $("#ContentPlaceHolder1_txtVAT").keyup(function () {
                //var vat = $('#txtTP').val() * .175;
                //$('#txtTotalSellPrice').val($('#txtSellPrice').val() * $('#txtTotalPcs').val());
                //$('#txtVAT').val(vat.toFixed(2));

                var count = $('#ContentPlaceHolder1_txtTotalPcs').val();
                var f = $('#ContentPlaceHolder1_txtBuyPriceFactor').val();

                var tot_price = parseFloat($('#ContentPlaceHolder1_txtTP').val()); // +parseFloat($('#txtVAT').val());

                var net_price = tot_price * (1 - f);
                var unit_price = (parseFloat(net_price) + parseFloat($('#ContentPlaceHolder1_txtVAT').val())) / count;


                var tot_price_with_vat = parseFloat(net_price) + parseFloat($('#ContentPlaceHolder1_txtVAT').val());

                $('#ContentPlaceHolder1_txtUnitPrice').val(unit_price.toFixed(2));

                $('#ContentPlaceHolder1_txtTotalBuyPrice').val(tot_price_with_vat.toFixed(2));

            });



            /*
            $("#txtTotalDiscount").keyup(function () {
            $('#txtNetTotal').val($('#txtInvoiceAmount').val() - $('#txtTotalDiscount').val());
            });

            $("#txtPaidAmount").keyup(function () {
            $('#txtChange').val($('#txtPaidAmount').val() - $('#txtNetTotal').val());

            //alert($('#txtNetAmount').val());
            });
            */
        });


        function Check_STOCKInput() {

            var buyprice = document.getElementById("ContentPlaceHolder1_txtUnitPrice").value;
            var sellprice = document.getElementById("ContentPlaceHolder1_txtSellPrice").value;
            if (parseFloat(sellprice) < parseFloat(buyprice)) {
                alert('Sell Price Can Not Be Less Than Buy Price');
                return false;
            } else {
                return true;
            }
        }
    </script>
