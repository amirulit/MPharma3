    </script>
    <script type="text/javascript">
        function Validate() {

            var error = "";

            var v_cash_amt = parseFloat(document.getElementById("ContentPlaceHolder1_txtCashAmount").value);
            var v_MFS_amt = parseFloat(document.getElementById("ContentPlaceHolder1_txtMFSAmount").value);
            var v_card_amt = parseFloat(document.getElementById("ContentPlaceHolder1_txtCardAmount").value);



            var PaidAmount = document.getElementById("ContentPlaceHolder1_txtPaidAmount").value
            if (PaidAmount == "" || PaidAmount == "0" || PaidAmount == "0.00") {
                document.getElementById("ContentPlaceHolder1_txtPaidAmount").style.background = "red"
                error = error + "Invalid Paid Amount\n";
                //alert('Error : Invalid Paid Amount');
                //return false;
            }

            if ((v_cash_amt + v_MFS_amt + v_card_amt) != parseFloat(PaidAmount)) {
                error = error + "Cash Amount+MFS Amount+Card Amount <> Paid Amount\n";
            }

            if (error != "") {
                error = "Following error occurred\n" + error;
                alert(error);
                return false;
            }
            else {
                return true;
            }
        }

        function Check() {

            var InvoiceNO = document.getElementById("ContentPlaceHolder1_txtInvoiceNO").value;

            if (InvoiceNO == "") {
                alert('Invoice NO Can Not Be Blank');
                return false;
            } else {
                return true;
            }
        }

    </script>
